rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isTeamOwner(teamId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)).data.role == "owner";
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      match /memberships/{teamId} {
        allow read, write: if (isSignedIn() && request.auth.uid == userId) || isTeamOwner(teamId);
      }
    }

    match /teams/{teamId} {
      allow read, create, update: if isSignedIn();

      match /members/{userId} {
        allow read: if isSignedIn();
        allow write: if (isSignedIn() && request.auth.uid == userId) || isTeamOwner(teamId);
      }

      match /tasks/{taskId} {
        allow read, write: if isSignedIn();
      }
    }
  }
}
